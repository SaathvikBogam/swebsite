---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { contentSlug } from "../../lib/contentSlug";
import { groupNotesBySection } from "../../lib/groupNotes";

const all = await getCollection("notes");
const published = all.filter((n) => !n.data.draft);
const notes = groupNotesBySection(published).flatMap(({ notes }) => notes);

const defaultImage = "/images/notes/vector-calculus.svg";
---

<BaseLayout title="Notes" description="Lecture notes and write-ups." wide>
  <div class="notes-page">
    <h1 class="notes-page-title">Notes</h1>

    <ul class="notes-cards">
      {
        notes.map((note) => (
          <li>
            <a class="note-card" href={`/notes/${contentSlug(note.id)}`}>
              <img
                class="note-card-image"
                src={note.data.image ?? defaultImage}
                alt=""
                width="140"
                height="140"
                loading="lazy"
                decoding="async"
              />
              <div class="note-card-body">
                <h2 class="note-card-title">{note.data.title}</h2>
                <p class="note-card-desc">{note.data.description}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>

<style>
  .notes-page {
    --notes-card-bg: #262614;
    --notes-card-border: rgba(180, 200, 170, 0.12);
    --notes-heading: #a8d8c8;
    --notes-desc: #a39e90;
  }

  .notes-page-title {
    margin-bottom: 2rem;
    color: var(--notes-heading);
  }

  .notes-cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .note-card {
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
    padding: 1rem 1.15rem;
    background: var(--notes-card-bg);
    border: 1px solid var(--notes-card-border);
    border-radius: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .note-card:hover {
    border-color: rgba(168, 216, 200, 0.35);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .note-card-image {
    flex-shrink: 0;
    width: 7.5rem;
    height: 7.5rem;
    object-fit: contain;
    border-radius: 0.65rem;
    background: #121810;
  }

  .note-card-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.15rem 0;
  }

  .note-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--notes-heading);
    line-height: 1.25;
  }

  .note-card-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--notes-desc);
  }

  @media (max-width: 520px) {
    .note-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .note-card-image {
      width: 100%;
      height: auto;
      max-height: 10rem;
      aspect-ratio: 16 / 10;
    }
  }
</style>
