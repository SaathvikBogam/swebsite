---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { contentSlug } from "../../lib/contentSlug";
import { sitePath } from "../../lib/sitePath";

const all = await getCollection("notes");
const published = all.filter((n) => !n.data.draft);
const notes = [...published].sort((a, b) => {
  if (a.data.order === b.data.order) {
    return a.data.title.localeCompare(b.data.title);
  }
  return a.data.order - b.data.order;
});
const notesWithContent = await Promise.all(
  notes.map(async (note) => {
    const rendered = await note.render();
    return { note, Content: rendered.Content };
  })
);

const defaultImage = sitePath("/images/notes/vector-calculus.svg");
---

<BaseLayout title="Notes" description="Lecture notes and write-ups." wide>
  <div class="notes-page">
    <h1 class="notes-page-title">Notes</h1>

    <ul class="notes-cards">
      {
        notesWithContent.map(({ note, Content }) => (
          <li>
            <details class="note-card">
              <summary class="note-card-summary">
                <img
                  class="note-card-image"
                  src={sitePath(note.data.image ?? defaultImage)}
                  alt=""
                  width="140"
                  height="140"
                  loading="lazy"
                  decoding="async"
                />
                <div class="note-card-body">
                  <h2 class="note-card-title">{note.data.title}</h2>
                  <p class="note-card-desc">{note.data.description}</p>
                </div>
              </summary>
              <div class="note-card-expanded">
                {note.data.pdf && (
                  <p class="pdf-link">
                    <a href={note.data.pdf}>Download PDF</a>
                  </p>
                )}
                <Content />
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>

<style>
  .notes-page {
    --notes-card-bg: #262614;
    --notes-card-border: rgba(180, 200, 170, 0.12);
    --notes-heading: #a8d8c8;
    --notes-desc: #a39e90;
  }

  .notes-page-title {
    margin-bottom: 2rem;
    color: var(--notes-heading);
  }

  .notes-cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .note-card {
    background: var(--notes-card-bg);
    border: 1px solid var(--notes-card-border);
    border-radius: 1.25rem;
    overflow: hidden;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .note-card:hover {
    border-color: rgba(168, 216, 200, 0.35);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .note-card-summary {
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
    padding: 1rem 1.15rem;
    cursor: pointer;
    list-style: none;
    color: inherit;
  }

  .note-card-summary::-webkit-details-marker {
    display: none;
  }

  .note-card[open] {
    border-color: rgba(168, 216, 200, 0.35);
  }

  .note-card-image {
    flex-shrink: 0;
    width: 7.5rem;
    height: 7.5rem;
    object-fit: contain;
    border-radius: 0.65rem;
    background: #121810;
  }

  .note-card-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.15rem 0;
  }

  .note-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--notes-heading);
    line-height: 1.25;
  }

  .note-card-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--notes-desc);
  }

  .note-card-expanded {
    padding: 0 1.15rem 1.25rem;
    color: var(--text);
  }

  .pdf-link {
    margin: 0 0 1rem;
  }

  .pdf-link a {
    color: var(--notes-heading);
    text-decoration: underline;
  }

  @media (max-width: 520px) {
    .note-card-summary {
      flex-direction: column;
      align-items: flex-start;
    }

    .note-card-image {
      width: 100%;
      height: auto;
      max-height: 10rem;
      aspect-ratio: 16 / 10;
    }
  }
</style>
