---
import { sitePath } from "../lib/sitePath";

interface Props {
  title: string;
  description?: string;
  /** Wider main column (e.g. home page with side-by-side layout). */
  wide?: boolean;
  pageClass?: string;
}

const { title, description, wide = false, pageClass = "" } = Astro.props;

import "../styles/computer-modern.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0nivMqMOBaa0CWjRkGhARqiFDJW906fjcICotTI3bbIcFQX29zFR2QI5IkzpF1"
      crossorigin="anonymous"
    />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class:list={pageClass ? [pageClass] : []}>
    <a class="skip" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="inner">
        <a class="brand" href={sitePath("/")}>Saathvik Bogam</a>
        <nav aria-label="Primary">
          <a href={sitePath("/")}>Home</a>
          <a href={sitePath("/journey/")}>Journey</a>
          <a href={sitePath("/notes/")}>Notes</a>
        </nav>
      </div>
    </header>
    <main id="main" class:list={["main", wide && "main--wide"]}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="inner">
        <p>
          Get in touch with me at saathvik25@iiserb.ac.in —
          <a href={sitePath("/CV.pdf")} target="_blank" rel="noopener noreferrer">View my CV</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #faf8f5;
    --fg: #1a1714;
    --muted: #5c5650;
    --accent: #2d4a6f;
    --border: #e3ddd4;
    --font-serif: "CMU Serif", "Computer Modern", "Latin Modern Roman", serif;
    --font-mono: "CMU Typewriter Text", "Computer Modern Typewriter", monospace;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 112.5%;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--font-serif);
    background: var(--bg);
    color: var(--fg);
    line-height: 1.55;
  }

  .skip {
    position: absolute;
    left: -9999px;
    top: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--accent);
    color: #fff;
    z-index: 100;
  }

  .skip:focus {
    left: 0.5rem;
  }

  .site-header {
    border-bottom: 1px solid var(--border);
    background: rgba(250, 248, 245, 0.92);
    backdrop-filter: blur(6px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-header .inner,
  .site-footer .inner,
  .main {
    max-width: 42rem;
    margin: 0 auto;
    padding: 1rem 1.25rem;
  }

  .site-header .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }

  .brand {
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--fg);
    text-decoration: none;
  }

  .brand:hover {
    color: var(--accent);
  }

  .site-header nav {
    display: flex;
    gap: 1rem;
    font-size: 0.95rem;
  }

  .site-header nav a {
    color: var(--muted);
    text-decoration: none;
  }

  .site-header nav a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .main {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .main--wide {
    max-width: 56rem;
  }

  .site-header:has(+ .main--wide) .inner {
    max-width: 56rem;
  }

  body:has(.main--wide) .site-footer .inner {
    max-width: 56rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: auto;
    font-size: 0.85rem;
    color: var(--muted);
  }

  h1,
  h2,
  h3 {
    font-weight: 700;
    line-height: 1.2;
  }

  h1 {
    font-size: 2.25rem;
    margin-top: 0;
  }

  h2 {
    font-size: 1.5rem;
    margin-top: 2rem;
  }

  a {
    color: var(--accent);
  }

  code,
  pre {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  code {
    background: #eee8df;
    padding: 0.12em 0.35em;
    border-radius: 4px;
  }

  .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
  }

  /* Journey page — dark mode + page-specific tokens */
  body.journey-page {
    --bg: #11120f;
    --fg: #e8e4dc;
    --muted: #a39e90;
    --accent: #a8d8c8;
    --border: rgba(180, 200, 170, 0.12);
    background: var(--bg);
    color: var(--fg);
  }

  body.journey-page .site-header {
    background: rgba(17, 18, 15, 0.92);
    border-bottom-color: var(--border);
  }

  body.journey-page .site-footer {
    border-top-color: var(--border);
  }

  body.journey-page .site-header nav a {
    color: var(--muted);
  }

  body.journey-page .site-header nav a:hover,
  body.journey-page .brand:hover {
    color: var(--accent);
  }

  body.journey-page code {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Homepage — dark mode + page-specific tokens */
  body.home-page {
    --bg: #11120f;
    --fg: #e8e4dc;
    --muted: #a39e90;
    --accent: #a8d8c8;
    --border: rgba(180, 200, 170, 0.12);
    background: var(--bg);
    color: var(--fg);
  }

  body.home-page .site-header {
    background: rgba(17, 18, 15, 0.92);
    border-bottom-color: var(--border);
  }

  body.home-page .site-footer {
    border-top-color: var(--border);
  }

  body.home-page .brand,
  body.home-page h1 {
    color: var(--fg);
  }

  body.home-page .site-header nav a {
    color: var(--muted);
  }

  body.home-page .site-header nav a:hover,
  body.home-page .brand:hover {
    color: var(--accent);
  }

  body.home-page .lede,
  body.home-page .intro-followup,
  body.home-page .intro-visual figcaption {
    color: var(--muted);
  }

  body.home-page a {
    color: var(--accent);
  }

  body.home-page code {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Notes index — dark olive layout */
  body:has(.notes-page) {
    background: #1a1a10;
    color: #e8e4dc;
  }

  body:has(.notes-page) .site-header {
    background: rgba(26, 26, 16, 0.92);
    border-bottom-color: rgba(180, 200, 170, 0.12);
  }

  body:has(.notes-page) .brand,
  body:has(.notes-page) h1 {
    color: #e8e4dc;
  }

  body:has(.notes-page) .site-header nav a {
    color: #a39e90;
  }

  body:has(.notes-page) .site-header nav a:hover,
  body:has(.notes-page) .brand:hover {
    color: #a8d8c8;
  }

  body:has(.notes-page) .site-footer {
    border-top-color: rgba(180, 200, 170, 0.12);
    color: #a39e90;
  }

  body:has(.notes-page) code {
    background: rgba(255, 255, 255, 0.08);
  }
</style>
